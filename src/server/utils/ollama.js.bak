export async function callOllama(prompt, model = process.env.OLLAMA_MODEL, useJson = false) {
  const body = {
    model,
    prompt,
    stream: false,
    options: { temperature: 0.9, num_predict: 8192, seed: Math.floor(Math.random() * 1000000) }
  };
  if (useJson) body.format = 'json';
  const res = await fetch(process.env.OLLAMA_API_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  });
  const data = await res.json();
  return data.response;
}