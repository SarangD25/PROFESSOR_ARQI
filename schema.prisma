generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Wasp managed auth user
model User {
  id        String   @id @default(cuid())
  role      String   @default("student") // "student" or "teacher"
  createdAt DateTime @default(now())
}

// Organization created by teacher
model Organization {
  id        String       @id @default(cuid())
  name      String       @unique
  teacherId String
  createdAt   DateTime     @default(now())
  students    OrgStudent[]
  campaigns   Campaign[]
  assessments Assessment[]
  config      OrgConfig?
}

// Student in an organization (no login required)
model OrgStudent {
  id        String     @id @default(cuid())
  name      String
  rollNo    String
  section   String     @default("")
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  qrPapers    QRPaper[]
  assessments Assessment[]
  createdAt   DateTime   @default(now())

  @@unique([rollNo, orgId])
}

// Campaign/Test created by teacher
model Campaign {
  id         String       @id @default(cuid())
  title      String
  examName   String
  topic      String
  difficulty String
  deadline   DateTime
  teacherId  String
  orgId      String?
  mode       String       @default("individual") // "individual" or "org"
  createdAt  DateTime     @default(now())
  org        Organization? @relation(fields: [orgId], references: [id])
  qrPapers   QRPaper[]
}

// QR Paper - one per student per campaign
model QRPaper {
  id           String        @id @default(cuid())
  token        String        @unique
  signature    String
  studentId    String?       // for individual mode (User id)
  orgStudentId String?       // for org mode (OrgStudent id)
  campaignId   String
  isUsed       Boolean       @default(false)
  difficulty   String?       // adaptive difficulty override
  createdAt    DateTime      @default(now())
  campaign     Campaign      @relation(fields: [campaignId], references: [id])
  orgStudent   OrgStudent?   @relation(fields: [orgStudentId], references: [id])
  questionSets QuestionSet[]
}

// Generated question set for a paper
model QuestionSet {
  id           String    @id @default(cuid())
  qrPaperId    String
  questions    Json
  version      Int       @default(1)
  weakConcepts Json?
  createdAt    DateTime  @default(now())
  qrPaper      QRPaper   @relation(fields: [qrPaperId], references: [id])
  attempts     Attempt[]
}

// Student attempt/submission
model Attempt {
  id            String      @id @default(cuid())
  studentId     String?
  orgStudentId  String?
  questionSetId String
  answers       Json
  score         Float
  totalMarks    Float
  weakAreas     Json
  submittedAt   DateTime    @default(now())
  questionSet   QuestionSet @relation(fields: [questionSetId], references: [id])
}

// Weak areas for individual students
model WeakArea {
  id        String   @id @default(cuid())
  studentId String
  concept   String
  strength  Float
  updatedAt DateTime @updatedAt

  @@unique([studentId, concept])
}

// PYQ chunks for RAG
model PyqChunk {
  id        String  @id @default(cuid())
  examName  String
  topic     String
  content   String
  source    String?
  embedding Json?
  metadata  Json?
}

// Manual assessment entries (assignments, behavior, performance)
model Assessment {
  id           String       @id @default(cuid())
  orgStudentId String
  orgStudent   OrgStudent   @relation(fields: [orgStudentId], references: [id])
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id])
  type         String       // "assignment" | "behavior" | "performance"
  title        String
  description  String?
  marks        Float
  maxMarks     Float
  date         DateTime     @default(now())
  createdBy    String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// Global pool of previously generated questions — prevents repetition across papers
model GeneratedQuestionPool {
  id        String   @id @default(cuid())
  topic     String
  examName  String
  text      String
  concept   String
  type      String
  createdAt DateTime @default(now())

  @@index([topic, examName])
}

// Per-org weight config for combining scores
model OrgConfig {
  id                String       @id @default(cuid())
  orgId             String       @unique
  org               Organization @relation(fields: [orgId], references: [id])
  weightAssignment  Float        @default(0.30)
  weightBehavior    Float        @default(0.10)
  weightPerformance Float        @default(0.20)
  weightClassTest   Float        @default(0.40)
}
