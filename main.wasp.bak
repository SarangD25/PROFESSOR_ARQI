app professorArqi {
  wasp: {
    version: "^0.22.0"
  },
  title: "Professor ARQI",
  auth: {
    userEntity: User,
    methods: {
      email: {}
    },
    onAuthFailedRedirectTo: "/login"
  }
}

// Actions
action generateSecureQR {
  fn: import { generateSecureQR } from "@src/server/actions/generateSecureQR.js",
  entities: [User, QRPaper, Campaign]
}

action generateQuestions {
  fn: import { generateQuestions } from "@src/server/actions/generateQuestions.js",
  entities: [QRPaper, QuestionSet, WeakArea, PyqChunk]
}

action submitAttempt {
  fn: import { submitAttempt } from "@src/server/actions/submitAttempt.js",
  entities: [Attempt, QuestionSet, WeakArea]
}

action createCampaign {
  fn: import { createCampaign } from "@src/server/actions/createCampaign.js",
  entities: [Campaign]
}

// Queries
query getPaper {
  fn: import { getPaper } from "@src/server/queries/getPaper.js",
  entities: [QRPaper, QuestionSet, Campaign]
}

query getStudentWeakAreas {
  fn: import { getStudentWeakAreas } from "@src/server/queries/getStudentWeakAreas.js",
  entities: [WeakArea]
}

query getCampaignAnalytics {
  fn: import { getCampaignAnalytics } from "@src/server/queries/getCampaignAnalytics.js",
  entities: [Campaign, QRPaper, QuestionSet, Attempt]
}

query getCampaigns {
  fn: import { getCampaigns } from "@src/server/queries/getCampaigns.js",
  entities: [Campaign]
}

// Routes
route Root { path: "/", to: HomePage }
route Login { path: "/login", to: LoginPage }
route Register { path: "/register", to: RegisterPage }
route StudentDashboard { path: "/student", to: StudentDashboardPage, authRequired: true }
route TeacherDashboard { path: "/teacher", to: TeacherDashboardPage, authRequired: true }
route CreateCampaign { path: "/teacher/campaigns/new", to: CreateCampaignPage, authRequired: true }
route PaperView { path: "/paper/:token", to: PaperViewPage }
route QRDisplay { path: "/qr/:token", to: QRDisplayPage, authRequired: true }

// Pages
page HomePage {
  component: import { Home } from "@src/client/pages/Home.jsx"
}
page LoginPage {
  component: import { Login } from "@src/client/pages/Login.jsx"
}
page RegisterPage {
  component: import { Register } from "@src/client/pages/Register.jsx"
}
page StudentDashboardPage {
  component: import { StudentDashboard } from "@src/client/pages/StudentDashboard.jsx"
}
page TeacherDashboardPage {
  component: import { TeacherDashboard } from "@src/client/pages/TeacherDashboard.jsx"
}
page CreateCampaignPage {
  component: import { CreateCampaign } from "@src/client/pages/CreateCampaign.jsx"
}
page PaperViewPage {
  component: import { PaperView } from "@src/client/pages/PaperView.jsx"
}
page QRDisplayPage {
  component: import { QRDisplay } from "@src/client/pages/QRDisplay.jsx"
}